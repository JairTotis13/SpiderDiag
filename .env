# SpiderDiag Environment Configuration
# Copy to .env and adjust values

# ── Supabase (cloud) ────────────────────────────────────────────
# Fill these if using Supabase. Set USE_LOCAL_DB=false
SUPABASE_DB_HOST=db.yourproject.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your-db-password
SUPABASE_DB_NAME=postgres
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Local PostgreSQL (development) ─────────────────────────────
USE_LOCAL_DB=true
LOCAL_DB_HOST=localhost
LOCAL_DB_PORT=5432
LOCAL_DB_USER=spiderdiag
LOCAL_DB_PASSWORD=spiderdiag
LOCAL_DB_NAME=spiderdiag

# ── JWT ─────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-secret-key-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Backend ─────────────────────────────────────────────────────
BACKEND_PORT=8000

# ── Frontend ────────────────────────────────────────────────────
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000/ws

# ── CORS ────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── OBD-II ──────────────────────────────────────────────────────
OBD_PORT=/dev/ttyUSB0
OBD_BAUDRATE=38400
OBD_TIMEOUT=30
